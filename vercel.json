{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "redirects": [
    { "source": "/", "destination": "/en", "permanent": false },
    { "source": "/publish",                   "destination": "/en/publish",                   "permanent": false },
    { "source": "/publish/computer",          "destination": "/en/publish/computer",          "permanent": false },
    { "source": "/publish/browser",           "destination": "/en/publish/browser",           "permanent": false },
    { "source": "/publish/browser-extension", "destination": "/en/publish/browser-extension", "permanent": false },
    { "source": "/publish/mobile",            "destination": "/en/publish/mobile",            "permanent": false },
    { "source": "/publish/mcp",               "destination": "/en/publish/computer",          "permanent": true },
    { "source": "/publish/ai-apps",           "destination": "/en/publish/browser",           "permanent": true },
    { "source": "/publish/extensions",        "destination": "/en/publish/browser-extension", "permanent": true },
    { "source": "/publish/bots",              "destination": "/en/publish/mobile",            "permanent": true },
    { "source": "/publish/no-code",           "destination": "/publish",                      "permanent": true },
    { "source": "/en/publish/mcp",            "destination": "/en/publish/computer",          "permanent": true },
    { "source": "/en/publish/ai-apps",        "destination": "/en/publish/browser",           "permanent": true },
    { "source": "/en/publish/extensions",     "destination": "/en/publish/browser-extension", "permanent": true },
    { "source": "/en/publish/bots",           "destination": "/en/publish/mobile",            "permanent": true },
    { "source": "/en/publish/no-code",        "destination": "/en/publish",                   "permanent": true },
    { "source": "/ads",        "destination": "/en/ads",        "permanent": false },
    { "source": "/developer",  "destination": "/publish/dashboard", "permanent": false },
    { "source": "/advertiser", "destination": "/ads/dashboard",     "permanent": false },
    { "source": "/signup",     "destination": "/",                  "permanent": false },
    { "source": "/login",      "destination": "/",                  "permanent": false },
    { "source": "/test/lumi-snippet-test", "destination": "/admin/qa/lumi-snippet-test", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/help/article",
      "has": [{ "type": "host", "value": "affiliate.boostboss.ai" }],
      "destination": "/affiliate-help-article.html"
    },
    {
      "source": "/help",
      "has": [{ "type": "host", "value": "affiliate.boostboss.ai" }],
      "destination": "/affiliate-help.html"
    },
    {
      "source": "/signin",
      "has": [{ "type": "host", "value": "affiliate.boostboss.ai" }],
      "destination": "/affiliate-signin.html"
    },
    {
      "source": "/signup",
      "has": [{ "type": "host", "value": "affiliate.boostboss.ai" }],
      "destination": "/affiliate-signup.html"
    },
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "affiliate.boostboss.ai" }],
      "destination": "/affiliate.html"
    },
    { "source": "/affiliate", "destination": "/affiliate.html" },
    { "source": "/affiliate/signin", "destination": "/affiliate-signin.html" },
    { "source": "/affiliate/signup", "destination": "/affiliate-signup.html" },
    { "source": "/affiliate/help", "destination": "/affiliate-help.html" },
    { "source": "/affiliate/help/article", "destination": "/affiliate-help-article.html" },
    { "source": "/help", "destination": "/affiliate-help.html" },
    { "source": "/help/article", "destination": "/affiliate-help-article.html" },
    { "source": "/s/:token", "destination": "/api/affiliate-redirect?token=:token" },
    { "source": "/p/:token", "destination": "/product.html?id=:token" },
    { "source": "/buy/:token", "destination": "/checkout.html?id=:token" },
    { "source": "/buy/:token/success", "destination": "/checkout-success.html?id=:token" },
    { "source": "/buy/:token/cancelled", "destination": "/checkout-cancelled.html?id=:token" },
    { "source": "/v1/vouchers/validate", "destination": "/api/vouchers?action=validate" },
    { "source": "/v1/vouchers/redeem",   "destination": "/api/vouchers?action=redeem" },
    { "source": "/api/conversions/postback", "destination": "/api/conversions?action=postback" },
    { "source": "/v1/conversion", "destination": "/api/conversions?action=postback" },
    { "source": "/en", "destination": "/index.html" },
    { "source": "/zh", "destination": "/index.html" },
    { "source": "/zh-TW", "destination": "/index.html" },
    { "source": "/ja", "destination": "/index.html" },
    { "source": "/ko", "destination": "/index.html" },
    { "source": "/vi", "destination": "/index.html" },
    { "source": "/ads", "destination": "/ads.html" },
    { "source": "/:lang(en|zh|zh-TW|ja|ko|vi)/ads", "destination": "/ads.html" },
    { "source": "/ads/dashboard",     "destination": "/advertiser.html" },
    { "source": "/publish/dashboard", "destination": "/developer.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/publish/signup", "destination": "/signup.html" },
    { "source": "/publish/signin", "destination": "/signup.html" },
    { "source": "/ads/signup", "destination": "/signup.html" },
    { "source": "/ads/signin", "destination": "/signup.html" },

    { "source": "/ads/check-email",         "destination": "/auth-flow.html" },
    { "source": "/ads/confirm",             "destination": "/auth-flow.html" },
    { "source": "/ads/forgot-password",     "destination": "/auth-flow.html" },
    { "source": "/ads/reset-password",      "destination": "/auth-flow.html" },
    { "source": "/publish/check-email",     "destination": "/auth-flow.html" },
    { "source": "/publish/confirm",         "destination": "/auth-flow.html" },
    { "source": "/publish/forgot-password", "destination": "/auth-flow.html" },
    { "source": "/publish/reset-password",  "destination": "/auth-flow.html" },

    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/payouts", "destination": "/admin-payouts.html" },
    { "source": "/admin/qa/lumi-snippet-test", "destination": "/admin-qa-lumi-snippet-test.html" },
    { "source": "/status", "destination": "/status.html" },
    { "source": "/playground", "destination": "/playground.html" },
    { "source": "/v1/ad-request", "destination": "/api/ad-request" },
    { "source": "/lumi/v1.js", "destination": "/lumi-v1.js" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/docs/quickstart", "destination": "/docs-quickstart.html" },
    { "source": "/docs/activation-link", "destination": "/docs-activation-link.html" },
    { "source": "/docs/product-lifecycle", "destination": "/docs-product-lifecycle.html" },
    { "source": "/docs/api-reference", "destination": "/docs-api-reference.html" },
    { "source": "/docs/browser", "destination": "/docs-browser.html" },
    { "source": "/docs/browser/react", "destination": "/docs-browser-react.html" },
    { "source": "/docs/computer", "destination": "/docs-computer.html" },
    { "source": "/docs/extension", "destination": "/docs-extension.html" },
    { "source": "/docs/mobile", "destination": "/docs-mobile.html" },
    { "source": "/docs/mcp", "destination": "/docs-mcp.html" },
    { "source": "/docs/js-snippet", "destination": "/docs-js-snippet.html" },
    { "source": "/docs/npm-sdk", "destination": "/docs-npm-sdk.html" },
    { "source": "/docs/rest-api", "destination": "/docs-rest-api.html" },
    { "source": "/docs/payouts", "destination": "/docs-payouts.html" },
    { "source": "/docs/reporting", "destination": "/docs-reporting.html" },
    { "source": "/exchange", "destination": "/exchange.html" },
    { "source": "/publish", "destination": "/publish.html" },
    { "source": "/publish/computer", "destination": "/publish-computer.html" },
    { "source": "/publish/browser", "destination": "/publish-browser.html" },
    { "source": "/publish/browser-extension", "destination": "/publish-browser-extension.html" },
    { "source": "/publish/mobile", "destination": "/publish-mobile.html" },
    { "source": "/:lang(en|zh|zh-TW|ja|ko|vi)/publish", "destination": "/publish.html" },
    { "source": "/:lang(en|zh|zh-TW|ja|ko|vi)/publish/computer", "destination": "/publish-computer.html" },
    { "source": "/:lang(en|zh|zh-TW|ja|ko|vi)/publish/browser", "destination": "/publish-browser.html" },
    { "source": "/:lang(en|zh|zh-TW|ja|ko|vi)/publish/browser-extension", "destination": "/publish-browser-extension.html" },
    { "source": "/:lang(en|zh|zh-TW|ja|ko|vi)/publish/mobile", "destination": "/publish-mobile.html" },
    { "source": "/test/lumi-snippet-test", "destination": "/test/lumi-snippet-test.html" },
    { "source": "/trust", "destination": "/trust.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/refunds", "destination": "/refunds.html" },
    { "source": "/aup", "destination": "/aup.html" },
    { "source": "/cookies", "destination": "/cookies.html" },
    { "source": "/publisher-agreement", "destination": "/publisher-agreement.html" },
    { "source": "/advertiser-terms", "destination": "/advertiser-terms.html" },
    { "source": "/about", "destination": "/about.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/sdk.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/lumi.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/lumi-v1.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=86400, stale-while-revalidate=604800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Lumi-Door", "value": "browser-app" }
      ]
    },
    {
      "source": "/pixel.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Cache-Control", "value": "public, max-age=300" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, Stripe-Signature, PayPal-Transmission-Id, PayPal-Transmission-Time, PayPal-Transmission-Sig, PayPal-Cert-Url, PayPal-Auth-Algo, x-openrtb-version" }
      ]
    },
    {
      "source": "/sellers.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/app-ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/stats?type=aggregate",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/campaigns?action=embed_drain",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/stats?type=recon",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/billing?action=run_payout_cron",
      "schedule": "0 12 * * 5"
    },
    {
      "path": "/api/billing?action=run_payout_retry_sweep",
      "schedule": "0 12 * * 6"
    },
    {
      "path": "/api/admin-seller-payouts?action=dispatch_batch",
      "schedule": "30 12 * * 6"
    },
    {
      "path": "/api/conversions?action=auto_confirm",
      "schedule": "30 12 * * *"
    }
  ]
}
