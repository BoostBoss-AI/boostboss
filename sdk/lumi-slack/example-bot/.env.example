# Slack — from api.slack.com/apps → Your App
SLACK_BOT_TOKEN=xoxb-...                # OAuth & Permissions → Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...                # Basic Information → App-Level Tokens (with connections:write)
SLACK_SIGNING_SECRET=...                # Basic Information → App Credentials → Signing Secret

# Boost Boss — sandbox key for the validation. Use a real sk_live_ in prod.
BOOSTBOSS_API_KEY=sk_test_demo
