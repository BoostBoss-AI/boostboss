{
  "manifest_version": 3,
  "name": "Lumi SDK · Door 3 validation",
  "version": "0.0.1",
  "description": "Throwaway Chrome extension demonstrating @boostbossai/lumi-sdk in a side panel. Internal validation only — not published.",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": ["https://boostboss.ai/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Lumi SDK side panel"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://boostboss.ai 'self'"
  }
}
