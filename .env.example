# ═══════════════════════════════════════════════════════════════════════
# BOOST BOSS — Environment Variables
# Copy to .env.local for local dev, or set in Vercel → Settings → Env Vars
# ═══════════════════════════════════════════════════════════════════════

# ── Supabase (required for production) ────────────────────────────────
# Get from: supabase.com → Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Auth ──────────────────────────────────────────────────────────────
# Random 32+ char string. openssl rand -hex 32
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# ── Stripe (required for billing) ────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Get from: dashboard.stripe.com → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── RTB / BBX ─────────────────────────────────────────────────────────
# Set to "true" to require Bearer auth on all /api/rtb POST requests.
# Unauthenticated bids are rejected with 401. Always "true" in production.
BBX_SEAT_AUTH_REQUIRED=true

# Revenue split (updated 2026-06-04).
#
# Two distinct fees comprise the 30% Boost Boss share. They are kept as
# separate variables so each can be tuned independently and so they can
# be attributed correctly in accounting (the RTB fee is invoiced to the
# advertiser as a demand-side fee; the network take is platform margin).
#
#   advertiser_gross   = winning bid price
#   rtb_fee            = advertiser_gross * BBX_RTB_FEE       (charged to advertiser, demand-side)
#   network_take       = advertiser_gross * BBX_NETWORK_TAKE  (Boost Boss platform margin)
#   publisher_share    = advertiser_gross * (1 - BBX_RTB_FEE - BBX_NETWORK_TAKE)
#
# Defaults: 6.5% RTB + 23.5% network = 30% total → publisher receives 70%.
#
# BBX_TAKE_RATE (legacy single-variable name) is still read for backward
# compatibility — if set, it overrides the sum of the two new vars.
BBX_RTB_FEE=0.065
BBX_NETWORK_TAKE=0.235

# Minimum payout threshold in USD (default $100).
BBX_MIN_PAYOUT=100

# Public base URL for callback URLs, nurl macros, etc.
BOOSTBOSS_BASE_URL=https://boostboss.ai

# ── Vercel ────────────────────────────────────────────────────────────
# Set automatically by Vercel, but declare for local dev:
NODE_ENV=production
